# Aarogya Foundation — client environment (Vite)
# Copy to `.env`. Vite only exposes vars prefixed with VITE_.

# Base URL of the Express API
VITE_API_URL=http://localhost:5000/api

# Razorpay public key id (test mode). Safe to expose; the secret stays server-side.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# Public site URL (used for canonical/OG tags)
VITE_SITE_URL=http://localhost:5173
