# ─────────────────────────────────────────────────────────────
# Aarogya Foundation — server environment
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=5000

# Where the React client is served (used for CORS + email links)
CLIENT_URL=http://localhost:5173

# MongoDB connection string (local or MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/aarogya

# Auth — generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Seed admin (created by `npm run seed`)
SEED_ADMIN_EMAIL=admin@aarogyafoundation.org
SEED_ADMIN_PASSWORD=Admin@12345
SEED_EDITOR_EMAIL=editor@aarogyafoundation.org
SEED_EDITOR_PASSWORD=Editor@12345

# Razorpay (test mode keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# SMTP for transactional email (Mailtrap/Gmail/SendGrid SMTP, etc.)
# Leave SMTP_HOST blank to log emails to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Aarogya Foundation <no-reply@aarogyafoundation.org>"
ADMIN_NOTIFY_EMAIL=admin@aarogyafoundation.org
